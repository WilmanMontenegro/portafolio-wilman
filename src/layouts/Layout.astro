---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'wilman.dev',
  description = 'Full Stack Developer especializado en construir experiencias digitales modernas.',
  image = '/favicon.svg',
} = Astro.props;

const canonical = Astro.url?.href;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content="#100425" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url).href} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.url).href} />
    {canonical && <link rel="canonical" href={canonical} />}
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css" />
    <title>{title}</title>
  </head>
  <body>
    <a class="absolute -top-12 left-4 z-[2000] py-3 px-4 rounded bg-purple text-white font-mono text-sm focus:top-4" href="#content">Saltar al contenido</a>
    <Navbar />
    <main class="pt-6" id="content">
      <slot />
    </main>
  </body>
</html>

