---
import Layout from '../../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;

const title = 'Blog';
const description = 'Artículos sobre desarrollo web, tecnología y emprendimiento digital por Wilman Montenegro.';

const posts = [
  {
    title: '¿Cómo un sitio web puede hacer crecer tu negocio?',
    description:
      'Descubre por qué un sitio web es la inversión más importante que puede hacer tu negocio: visibilidad, ventas y presencia digital.',
    href: `${base}blog/sitio-web-negocio`,
    date: 'Abr 3, 2026',
  },
  {
    title: 'El impacto de la inteligencia artificial en la mente humana',
    description:
      'Reflexión sobre productividad, ansiedad y cómo usar la IA como copiloto sin perder criterio humano.',
    href: `${base}blog/impacto-de-la-inteligencia-artificial-en-la-mente-humana`,
    date: 'Abr 1, 2026',
  },
];
---

<Layout title={`${title} | Wilman Montenegro`} description={description}>
  <section class="section-wrapper" aria-labelledby="blog-index-title">
    <p class="mb-2 font-mono text-[0.82rem] tracking-[0.05em] text-cyan/65" aria-hidden="true">
      &lt;section&gt; blog
    </p>

    <div class="mb-8 flex items-end justify-between gap-4">
      <h1 id="blog-index-title" class="grad-text font-mono text-[clamp(1.7rem,3vw,2.4rem)] font-bold">
        Blog
      </h1>
      <a
        href={`${base}#blog`}
        class="font-mono text-[0.8rem] text-cyan/60 transition-opacity hover:opacity-70"
      >
        ← Volver al inicio
      </a>
    </div>

    <div class="grid gap-5">
      {posts.map((post) => (
        <article class="rounded-xl border border-purple/20 bg-[rgba(27,8,64,0.6)] p-[1.4rem] transition-[border-color,box-shadow] duration-200 hover:border-purple/50 hover:shadow-[0_0_30px_rgba(125,71,255,0.15)]">
          <p class="mb-1 font-mono text-[0.75rem] text-cyan/50">{post.date}</p>
          <h2 class="grad-text mb-2 font-mono text-[clamp(1.1rem,2.2vw,1.4rem)] font-bold leading-snug">
            {post.title}
          </h2>
          <p class="mb-4 text-[0.92rem] leading-[1.8] text-muted">{post.description}</p>
          <a
            href={post.href}
            class="font-mono text-[0.82rem] text-cyan transition-opacity hover:opacity-70"
            aria-label={`Leer artículo: ${post.title}`}
          >
            Leer artículo →
          </a>
        </article>
      ))}
    </div>

    <p class="mt-2 mb-0 text-right font-mono text-[0.82rem] tracking-[0.05em] text-cyan/65" aria-hidden="true">
      &lt;/section&gt;
    </p>
  </section>
</Layout>
