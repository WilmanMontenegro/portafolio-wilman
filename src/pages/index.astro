---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';

const featuredProjects = [
  {
    year: '2026',
    title: 'FruitApp',
    description: 'Dirección técnica, experiencia de producto y construcción de interfaces enfocadas en operaciones reales.',
    stack: ['React', 'Node.js', 'Arquitectura'],
  },
  {
    year: '2025',
    title: 'Sistemas con IA aplicada',
    description: 'Automatización de flujos, agentes y herramientas internas para acelerar procesos sin perder control técnico.',
    stack: ['TypeScript', 'IA aplicada', 'Backend'],
  },
  {
    year: '2024',
    title: 'Plataformas web a medida',
    description: 'Diseño y desarrollo de productos digitales con foco en claridad visual, rendimiento y mantenibilidad.',
    stack: ['Astro', 'Vue', 'UX'],
  },
];

const experience = [
  {
    period: 'Actualidad',
    role: 'Líder Técnico & Cofundador',
    company: 'FruitApp',
    summary: 'Defino dirección técnica, experiencia de usuario y decisiones de arquitectura para un producto en crecimiento.',
  },
  {
    period: 'Últimos años',
    role: 'Full Stack Developer',
    company: 'Proyectos para clientes y productos propios',
    summary: 'He trabajado en frontend, backend, bases de datos y despliegues, cuidando tanto la experiencia como la solidez técnica.',
  },
  {
    period: 'En evolución',
    role: 'AI Agent Builder',
    company: 'Flujos internos y automatización',
    summary: 'Exploro agentes, procesos asistidos y productos donde la IA aporta velocidad sin comprometer claridad ni control.',
  },
];
---

<Layout>
  <Hero />

  <section class="section section--about" id="about" aria-labelledby="about-title">
    <p class="section__label"><span class="tag">&lt;section&gt;</span> about</p>
    <h2 class="section__title" id="about-title">Sobre Mí</h2>

    <div class="about-grid">
      <p class="about-text">
        Ingeniero de sistemas con experiencia en desarrollo full stack, liderazgo técnico e inteligencia artificial.
        Combino una base sólida de ingeniería con sensibilidad por la experiencia del usuario y el producto.
      </p>
      <div class="about-card">
        <p class="comment">// lo que me mueve</p>
        <p>Construir productos que funcionen bien, se vean bien y escalen sin drama.</p>
        <a href="#contact" class="link--accent">→ Conversemos</a>
      </div>
    </div>
    <p class="section__label section__label--close"><span class="tag">&lt;/section&gt;</span></p>
  </section>

  <section class="section" id="projects" aria-labelledby="projects-title">
    <p class="section__label"><span class="tag">&lt;section&gt;</span> projects</p>
    <h2 class="section__title" id="projects-title">Trabajo Seleccionado</h2>

    <div class="projects-grid">
      {featuredProjects.map((project) => (
        <article class="project-card">
          <p class="project-card__year"><span class="brace">{</span> {project.year} <span class="brace">}</span></p>
          <h3>{project.title}</h3>
          <p>{project.description}</p>
          <ul class="project-card__stack" aria-label={`Stack de ${project.title}`}>
            {project.stack.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>
    <p class="section__label section__label--close"><span class="tag">&lt;/section&gt;</span></p>
  </section>

  <section class="section" id="experience" aria-labelledby="experience-title">
    <p class="section__label"><span class="tag">&lt;section&gt;</span> experience</p>
    <h2 class="section__title" id="experience-title">Trayectoria</h2>

    <div class="timeline">
      {experience.map((item) => (
        <article class="timeline-item">
          <p class="timeline-item__period">{item.period}</p>
          <div>
            <h3>{item.role}</h3>
            <p class="timeline-item__company">{item.company}</p>
            <p>{item.summary}</p>
          </div>
        </article>
      ))}
    </div>
    <p class="section__label section__label--close"><span class="tag">&lt;/section&gt;</span></p>
  </section>

  <section class="section" id="contact" aria-labelledby="contact-title">
    <p class="section__label"><span class="tag">&lt;section&gt;</span> contact</p>
    <div class="contact-card">
      <h2 class="section__title" id="contact-title">¿Tienes un proyecto en mente?</h2>
      <p>
        Estoy disponible para colaborar en productos, sistemas frontend y decisiones técnicas.
        <span class="comment"> // canales públicos próximamente</span>
      </p>
      <div class="contact-actions flex flex-wrap gap-4">
        <a class="btn btn--primary" href="#projects">Ver Proyectos</a>
        <a class="btn btn--ghost" href="#experience">[ Experiencia ]</a>
      </div>
    </div>
    <p class="section__label section__label--close"><span class="tag">&lt;/section&gt;</span></p>
  </section>
</Layout>

<style>
  /* ── About ── */
  .about-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 2rem;
    align-items: start;
  }

  .section--about {
    padding-top: clamp(5rem, 12vw, 8rem);
    padding-bottom: clamp(5rem, 12vw, 8rem);
  }

  .section--about .section__title {
    font-size: clamp(2.2rem, 4.5vw, 3.2rem);
  }

  .about-text {
    font-size: clamp(1.1rem, 2vw, 1.3rem);
    line-height: 1.85;
    color: var(--color-muted);
  }

  .about-card {
    display: grid;
    gap: 1rem;
    padding: 1.75rem;
    border: 1px solid rgba(125, 71, 255, 0.25);
    border-radius: 12px;
    background: rgba(125, 71, 255, 0.06);
    font-size: 1.05rem;
  }

  .about-card p {
    color: var(--color-text);
    line-height: 1.7;
  }

  .link--accent {
    font-family: var(--font-family-mono);
    font-size: 0.85rem;
    color: var(--color-cyan);
    transition: opacity 0.2s;
  }

  .link--accent:hover {
    opacity: 0.7;
  }

  /* ── Projects ── */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .project-card {
    display: grid;
    gap: 0.75rem;
    padding: 1.4rem;
    border: 1px solid rgba(125, 71, 255, 0.2);
    border-radius: 12px;
    background: rgba(27, 8, 64, 0.6);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .project-card:hover {
    border-color: rgba(125, 71, 255, 0.5);
    box-shadow: 0 0 30px rgba(125, 71, 255, 0.15);
  }

  .project-card__year {
    font-family: var(--font-family-mono);
    font-size: 0.78rem;
    color: var(--color-cyan);
    opacity: 0.7;
  }

  .project-card h3 {
    font-family: var(--font-family-mono);
    font-size: 1.15rem;
    color: var(--color-text);
  }

  .project-card p {
    color: var(--color-muted);
    font-size: 0.92rem;
    line-height: 1.7;
  }

  .project-card__stack {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .project-card__stack li {
    padding: 0.4rem 0.75rem;
    border-radius: 4px;
    border: 1px solid rgba(12, 255, 255, 0.2);
    background: rgba(12, 255, 255, 0.06);
    color: var(--color-cyan);
    font-family: var(--font-family-mono);
    font-size: 0.75rem;
  }

  /* ── Timeline ── */
  .timeline {
    display: grid;
    gap: 0;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 10rem 1fr;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-top: 1px solid rgba(125, 71, 255, 0.15);
  }

  .timeline-item:last-child {
    border-bottom: 1px solid rgba(125, 71, 255, 0.15);
  }

  .timeline-item__period {
    font-family: var(--font-family-mono);
    font-size: 0.78rem;
    color: var(--color-cyan);
    opacity: 0.65;
    padding-top: 0.15rem;
  }

  .timeline-item h3 {
    font-family: var(--font-family-mono);
    font-size: 1.05rem;
    color: var(--color-text);
  }

  .timeline-item__company {
    margin: 0.25rem 0 0.5rem;
    color: var(--color-purple);
    font-family: var(--font-family-mono);
    font-size: 0.85rem;
  }

  .timeline-item p {
    color: var(--color-muted);
    font-size: 0.92rem;
    line-height: 1.7;
  }

  /* ── Contact ── */
  .contact-card {
    display: grid;
    gap: 1.25rem;
    padding: clamp(1.5rem, 5vw, 2.5rem);
    border-radius: 16px;
    border: 1px solid rgba(125, 71, 255, 0.25);
    background:
      linear-gradient(135deg, rgba(125, 71, 255, 0.1) 0%, rgba(12, 255, 255, 0.05) 100%);
  }

  .contact-card p {
    color: var(--color-muted);
    line-height: 1.7;
  }

  /* ── Responsive ── */
  @media (max-width: 960px) {
    .projects-grid,
    .about-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .timeline-item {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }
</style>
