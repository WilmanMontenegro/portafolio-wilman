---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Contact from '../components/Contact.astro';

const featuredProjects = [
  {
    year: 'Ene–Feb 2026',
    title: 'FruitApp',
    description: 'Marketplace multi-tenant para fruterías y tiendas de barrio. Desarrollado por contrato: catálogo, POS, pagos con Mercado Pago, tracking GPS en tiempo real y PWA sin instalación. 43 pantallas en 2 meses.',
    stack: ['Flutter', 'Firebase', 'Mercado Pago', 'Riverpod'],
    url: 'https://web.fruit-app.com',
  },
  {
    year: '2026',
    title: 'Batería Champetera Virtual',
    description: 'Aplicación web interactiva con batería y piano champetero virtual, samplers configurables y soporte completo para móvil.',
    stack: ['JavaScript', 'HTML5', 'CSS3'],
    url: 'https://bateriachampetera.com',
  },
  {
    year: '2026',
    title: 'TuPsicoana',
    description: 'Plataforma web para psicóloga en formación con blog de salud mental, sistema de contacto y contenido bilingüe.',
    stack: ['Next.js', 'TypeScript', 'CSS3'],
    url: 'https://www.tupsicoana.com/',
  },
  {
    year: '2025',
    title: 'Gimnasio Campestre Rodadero',
    description: 'Sitio institucional para colegio en Santa Marta con oferta académica, testimonios, formulario de admisiones y chat de WhatsApp.',
    stack: ['WordPress', 'PHP', 'Elementor'],
    url: 'https://gimnasiocampestrerodadero.edu.co/',
  },
  {
    year: '2025',
    title: 'Catalyx Group',
    description: 'Landing corporativa para consultora de software a medida, con secciones de servicios, enfoque y formulario de contacto.',
    stack: ['Astro', 'TypeScript', 'CSS3'],
    url: 'https://wilmanmontenegro.github.io/catalyx-group-website/',
  },
];

const experience = [
  {
    period: 'Ene 2026 – Actualidad',
    role: 'Desarrollador Full-Stack Freelance',
    company: 'Independiente · Remoto',
    summary: 'Desarrollo de aplicaciones web y móviles para emprendedores, pequeñas empresas e instituciones educativas. Marketplace, sitios corporativos y herramientas de gestión.',
  },
  {
    period: 'Jul 2024 – Ene 2026',
    role: 'Ingeniero de Desarrollo de Software',
    company: 'Zona Franca Las Américas S.A.S (Grupo Daabon) · Santa Marta',
    summary: 'Desarrollo y mantenimiento de aplicaciones empresariales, optimización de sistemas y automatización de procesos internos.',
  },
  {
    period: 'Mar 2022 – Nov 2024',
    role: 'Tutor de Programación Python',
    company: 'Kodland · Remoto (Singapur)',
    summary: 'Acompañamiento académico a estudiantes internacionales, resolución de dudas, evaluación de actividades y seguimiento del proceso de aprendizaje.',
  },
  {
    period: 'Jul 2022 – Abr 2023',
    role: 'Desarrollador Frontend Freelancer',
    company: 'BermaTech · Guayaquil, Ecuador (Remoto)',
    summary: 'Desarrollo de landing pages y aplicaciones web, implementación de interfaces y validación de diseños.',
  },
];
---

<Layout>
  <Hero />

  <section class="py-[clamp(2.5rem,6vw,4rem)] px-[clamp(1.25rem,5vw,3rem)] max-w-[var(--max-w)] mx-auto" id="about" aria-labelledby="about-title">
    <p class="font-mono text-[0.82rem] text-cyan/65 mb-2 tracking-[0.05em]">&lt;section&gt; about</p>
    <h2 class="grad-text font-mono text-[clamp(2.2rem,4.5vw,3.2rem)] font-bold mb-6" id="about-title">Sobre Mí</h2>

    <div class="about-grid">
      <p class="about-text">
        Ingeniero de Sistemas egresado de la Universidad del Magdalena, apasionado por la tecnología y la enseñanza.
        Trabajo como freelancer construyendo soluciones web y móviles para emprendedores, pequeñas empresas e instituciones educativas.
        En mis tiempos libres también instalo cámaras, formateo equipos y doy mantenimiento básico a computadores.
        Me mueve resolver problemas reales con tecnología bien hecha.
      </p>
      <div class="about-card">
        <p class="font-mono text-muted text-[0.78em]">// lo que me mueve</p>
        <p>Enseñar, construir y entregar productos que funcionen bien y se vean bien.</p>
        <a href="#contact" class="link--accent">→ Hablemos de tu proyecto</a>
      </div>
    </div>
    <p class="font-mono text-[0.82rem] text-cyan/65 mt-10 mb-0 text-right tracking-[0.05em]">&lt;/section&gt;</p>
  </section>

  <section class="py-[clamp(2.5rem,6vw,4rem)] px-[clamp(1.25rem,5vw,3rem)] max-w-[var(--max-w)] mx-auto" id="projects" aria-labelledby="projects-title">
    <p class="font-mono text-[0.82rem] text-cyan/65 mb-2 tracking-[0.05em]">&lt;section&gt; projects</p>
    <h2 class="grad-text font-mono text-[clamp(1.7rem,3vw,2.4rem)] font-bold mb-6" id="projects-title">Trabajo Seleccionado</h2>

    <div class="projects-grid">
      {featuredProjects.map((project) => (
        <article class="project-card">
          <p class="project-card__year"><span class="font-mono text-purple">{</span> {project.year} <span class="font-mono text-purple">}</span></p>
          <h3>{project.title}</h3>
          <p>{project.description}</p>
          <ul class="project-card__stack" aria-label={`Stack de ${project.title}`}>
            {project.stack.map((item) => <li>{item}</li>)}
          </ul>
          <a href={project.url} target="_blank" rel="noopener noreferrer" class="project-card__link">Ver proyecto →</a>
        </article>
      ))}
    </div>
    <p class="font-mono text-[0.82rem] text-cyan/65 mt-10 mb-0 text-right tracking-[0.05em]">&lt;/section&gt;</p>
  </section>

  <section class="py-[clamp(2.5rem,6vw,4rem)] px-[clamp(1.25rem,5vw,3rem)] max-w-[var(--max-w)] mx-auto" id="experience" aria-labelledby="experience-title">
    <p class="font-mono text-[0.82rem] text-cyan/65 mb-2 tracking-[0.05em]">&lt;section&gt; experience</p>
    <h2 class="grad-text font-mono text-[clamp(1.7rem,3vw,2.4rem)] font-bold mb-6" id="experience-title">Trayectoria</h2>

    <div class="timeline">
      {experience.map((item) => (
        <article class="timeline-item">
          <div class="timeline-item__connector" aria-hidden="true">
            <span class="timeline-item__dot"></span>
          </div>
          <div class="timeline-item__body">
            <p class="timeline-item__period">{item.period}</p>
            <h3>{item.role}</h3>
            <p class="timeline-item__company">{item.company}</p>
            <p class="timeline-item__summary">{item.summary}</p>
          </div>
        </article>
      ))}
    </div>
    <p class="font-mono text-[0.82rem] text-cyan/65 mt-10 mb-0 text-right tracking-[0.05em]">&lt;/section&gt;</p>
  </section>

  <Contact />
</Layout>

<style>
  /* ── About ── */
  .about-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 2rem;
    align-items: start;
  }

  .about-text {
    font-size: clamp(1.1rem, 2vw, 1.3rem);
    line-height: 1.85;
    color: var(--color-muted);
  }

  .about-card {
    display: grid;
    gap: 1rem;
    padding: 1.75rem;
    border: 1px solid rgba(125, 71, 255, 0.25);
    border-radius: 12px;
    background: rgba(125, 71, 255, 0.06);
    font-size: 1.05rem;
  }

  .about-card p {
    color: var(--color-text);
    line-height: 1.7;
  }

  .link--accent {
    font-family: var(--font-family-mono);
    font-size: 0.85rem;
    color: var(--color-cyan);
    transition: opacity 0.2s;
  }

  .link--accent:hover {
    opacity: 0.7;
  }

  /* ── Projects ── */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .project-card {
    display: grid;
    gap: 0.75rem;
    padding: 1.4rem;
    border: 1px solid rgba(125, 71, 255, 0.2);
    border-radius: 12px;
    background: rgba(27, 8, 64, 0.6);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .project-card:hover {
    border-color: rgba(125, 71, 255, 0.5);
    box-shadow: 0 0 30px rgba(125, 71, 255, 0.15);
  }

  .project-card__year {
    font-family: var(--font-family-mono);
    font-size: 0.78rem;
    color: var(--color-cyan);
    opacity: 0.7;
  }

  .project-card h3 {
    font-family: var(--font-family-mono);
    font-size: 1.15rem;
    color: var(--color-text);
  }

  .project-card p {
    color: var(--color-muted);
    font-size: 0.92rem;
    line-height: 1.7;
  }

  .project-card__stack {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .project-card__stack li {
    padding: 0.4rem 0.75rem;
    border-radius: 4px;
    border: 1px solid rgba(12, 255, 255, 0.2);
    background: rgba(12, 255, 255, 0.06);
    color: var(--color-cyan);
    font-family: var(--font-family-mono);
    font-size: 0.75rem;
  }

  .project-card__link {
    font-family: var(--font-family-mono);
    font-size: 0.82rem;
    color: var(--color-cyan);
    transition: opacity 0.2s;
    align-self: start;
  }

  .project-card__link:hover {
    opacity: 0.65;
  }

  /* ── Timeline ── */
  .timeline {
    display: grid;
    gap: 0;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 10rem 1fr;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-top: 1px solid rgba(125, 71, 255, 0.15);
  }

  .timeline-item:last-child {
    border-bottom: 1px solid rgba(125, 71, 255, 0.15);
  }

  .timeline-item__period {
    font-family: var(--font-family-mono);
    font-size: 0.78rem;
    color: var(--color-cyan);
    opacity: 0.65;
    padding-top: 0.15rem;
  }

  .timeline-item h3 {
    font-family: var(--font-family-mono);
    font-size: 1.05rem;
    color: var(--color-text);
  }

  .timeline-item__company {
    margin: 0.25rem 0 0.5rem;
    color: var(--color-purple);
    font-family: var(--font-family-mono);
    font-size: 0.85rem;
  }

  .timeline-item p {
    color: var(--color-muted);
    font-size: 0.92rem;
    line-height: 1.7;
  }

  /* ── Responsive ── */
  @media (max-width: 960px) {
    .projects-grid,
    .about-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .timeline-item {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }
</style>
