---
interface Experience {
    period: string;
    role: string;
    company: string;
    summary: string;
    tech: string[];
}

const experience: Experience[] = [
    {
        period: "Ene 2026 – Actualidad",
        role: "Desarrollador Full-Stack Freelance",
        company: "Independiente · Remoto",
        summary:
            "Desarrollo de aplicaciones web y móviles para emprendedores, pequeñas empresas e instituciones educativas. Marketplace, sitios corporativos y herramientas de gestión.",
        tech: ["Astro", "Vue", "Supabase", "Firebase", "Flutter", "Node.js", "Tailwind CSS"],
    },
    {
        period: "Jul 2024 – Ene 2026",
        role: "Ingeniero de Desarrollo de Software",
        company: "Zona Franca Las Américas S.A.S (Grupo Daabon) · Santa Marta",
        summary:
            "Desarrollo y mantenimiento de aplicaciones empresariales, optimización de sistemas y automatización de procesos internos.",
        tech: ["PHP", "Bootstrap", "jQuery", "MySQL", "JavaScript"],
    },
    {
        period: "Mar 2022 – Nov 2024",
        role: "Tutor de Programación Python",
        company: "Kodland · Remoto (Singapur)",
        summary:
            "Acompañamiento académico a estudiantes internacionales, resolución de dudas, evaluación de actividades y seguimiento del proceso de aprendizaje.",
        tech: ["Python"],
    },
    {
        period: "Jul 2022 – Abr 2023",
        role: "Desarrollador Frontend Freelancer",
        company: "BermaTech · Guayaquil, Ecuador (Remoto)",
        summary:
            "Desarrollo de landing pages y aplicaciones web, implementación de interfaces y validación de diseños.",
        tech: ["React", "Vite", "TypeScript", "JavaScript", "MySQL"],
    },
];
---

<section
    class="section-wrapper"
    id="experience"
    aria-labelledby="experience-title"
>
    <p class="font-mono text-[0.82rem] text-cyan/65 mb-2 tracking-[0.05em]" aria-hidden="true">
        &lt;section&gt; experience
    </p>
    <h2
        class="grad-text font-mono text-[clamp(1.7rem,3vw,2.4rem)] font-bold mb-6"
        id="experience-title"
    >
        Experiencia Profesional
    </h2>

    <div class="relative">
        {
            experience.map((item, index) => (
                <article class="relative pl-8 pb-10 last:pb-0 md:pl-10">
                    {index !== experience.length - 1 && (
                        <span
                            class="absolute left-[0.6rem] top-6 bottom-0 w-px bg-purple/25 md:left-[0.74rem]"
                            aria-hidden="true"
                        />
                    )}
                    <span
                        class="absolute left-0 top-2 h-5 w-5 rounded-full border border-cyan/30 bg-[linear-gradient(135deg,var(--color-purple),var(--color-cyan))] shadow-[0_0_14px_rgba(12,255,255,0.25)] md:h-6 md:w-6"
                        aria-hidden="true"
                    />

                    <p class="font-mono text-[0.78rem] text-cyan/65 tracking-[0.04em]">
                        {item.period}
                    </p>
                    <h3 class="mt-1 font-mono text-[1.05rem] text-text">
                        {item.role}
                    </h3>
                    <p class="mt-1 mb-2 font-mono text-[0.85rem] text-purple">
                        {item.company}
                    </p>
                    <p class="text-[0.92rem] leading-[1.7] text-muted">
                        {item.summary}
                    </p>
                    <ul class="mt-3 flex flex-wrap gap-2" aria-label="Tecnologías utilizadas">
                        {item.tech.map((t) => (
                            <li class="font-mono text-[0.72rem] px-2 py-0.5 rounded-md border border-cyan/20 bg-cyan/5 text-cyan/80">
                                {t}
                            </li>
                        ))}
                    </ul>
                </article>
            ))
        }
    </div>
    <p
        class="font-mono text-[0.82rem] text-cyan/65 mt-2 mb-0 text-right tracking-[0.05em]"
        aria-hidden="true"
    >
        &lt;/section&gt;
    </p>
</section>
