---
interface TechItem {
  label: string;
  iconClass: string;
}

const techStack: TechItem[] = [
  { label: 'JavaScript', iconClass: 'devicon-javascript-plain colored' },
  { label: 'TypeScript', iconClass: 'devicon-typescript-plain colored' },
  { label: 'PHP', iconClass: 'devicon-php-plain colored' },
  { label: 'Python', iconClass: 'devicon-python-plain colored' },
  { label: 'Dart', iconClass: 'devicon-dart-plain colored' },
  { label: 'C#', iconClass: 'devicon-csharp-plain colored' },
  { label: 'React', iconClass: 'devicon-react-original colored' },
  { label: 'Vue', iconClass: 'devicon-vuejs-plain colored' },
  { label: 'Angular', iconClass: 'devicon-angularjs-plain colored' },
  { label: 'Node.js', iconClass: 'devicon-nodejs-plain colored' },
  { label: 'NestJS', iconClass: 'devicon-nestjs-plain colored' },
  { label: 'Flutter', iconClass: 'devicon-flutter-plain colored' },
  { label: 'MySQL', iconClass: 'devicon-mysql-plain colored' },
  { label: 'PostgreSQL', iconClass: 'devicon-postgresql-plain colored' },
  { label: 'MongoDB', iconClass: 'devicon-mongodb-plain colored' },
  { label: 'Git', iconClass: 'devicon-git-plain colored' },
  { label: 'Linux', iconClass: 'devicon-linux-plain' },
];
---

<section class="mx-auto flex max-w-[var(--max-w)] items-center justify-center gap-12 rounded-[20px] bg-[linear-gradient(135deg,rgba(220,0,211,0.15)_0%,rgba(12,255,255,0.08)_100%)] px-8 py-[clamp(3rem,6vw,5rem)] max-[1024px]:flex-col max-[1024px]:justify-center max-[1024px]:gap-8 max-[640px]:rounded-xl max-[640px]:px-5 max-[640px]:py-10" id="home" aria-labelledby="hero-title">

  <!-- Foto -->
  <div class="hero-photo relative shrink-0 self-center">
    <img
      src={`${import.meta.env.BASE_URL}wilman-montenegro.webp`}
      alt="Wilman Montenegro"
      width="260"
      height="260"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      class="relative z-[2] block h-[260px] w-[260px] rounded-full border-[3px] border-[var(--color-bg)] object-cover object-top max-[1024px]:h-[200px] max-[1024px]:w-[200px] max-[640px]:h-[150px] max-[640px]:w-[150px]"
    />
  </div>

  <!-- Contenido -->
  <div class="w-full min-w-0 flex-1">

    <!-- Saludo -->
    <p class="mb-4 font-mono text-[0.85rem] text-muted">
      <span class="text-cyan/50">&lt;span&gt;</span>
      Hola, soy <strong class="bg-[linear-gradient(90deg,#e8e8f2,#0CFFFF)] bg-clip-text font-bold text-transparent">Wilman Montenegro</strong>
      <span class="text-cyan/50">&lt;/span&gt;</span>
    </p>

    <!-- Título con typewriter -->
    <h1 class="mb-5 font-mono text-[clamp(1.8rem,4vw,3rem)] font-bold leading-tight text-text" id="hero-title">
      Ingeniero de Sistemas &amp;<br>
      <span class="font-bold text-cyan">&#123;</span><span class="bg-[linear-gradient(90deg,#DC00D3,#0CFFFF)] bg-clip-text font-semibold text-transparent" id="typing"></span><span class="typing-cursor text-cyan">|</span><span class="font-bold text-cyan">&#125;</span>
    </h1>

    <!-- Descripción -->
    <p class="mb-7 text-justify hyphens-auto text-[0.97rem] leading-[1.8] text-muted">
      Ingeniero de Sistemas con experiencia en desarrollo web y móvil, entornos corporativos y proyectos propios.
      Apasionado por la tecnología y la enseñanza. Trabajo con emprendedores, pequeñas empresas e instituciones educativas construyendo soluciones reales.
    </p>

    <!-- Carrusel de tecnologías -->
    <div class="hero-stack mb-7 overflow-x-hidden" aria-label="Tecnologías que manejo" role="region" tabindex="0" id="hero-stack">
      <div class="stack-track flex w-max items-center gap-3" id="stack-track">
        {[...techStack, ...techStack].map((tech) => (
          <span class="stack-icon" data-label={tech.label}><i class={tech.iconClass} aria-hidden="true"></i></span>
        ))}
      </div>
    </div>

    <!-- CTAs -->
    <div class="mb-5 flex flex-wrap gap-3">
      <a class="btn btn--primary" href="#projects">Ver Proyectos</a>
      <a href={`${import.meta.env.BASE_URL}cv.pdf`} download="cv-wilman-montenegro.pdf" aria-label="Descargar CV en PDF" class="btn btn--ghost">[ Descargar CV ]</a>
    </div>

    <!-- Ubicación -->
    <p class="font-mono text-[0.78rem] text-muted/60">
      // Santa Marta, Colombia &middot; Disponible para proyectos remotos
    </p>

  </div>
</section>

<script>
  import tippy, { type Instance } from 'tippy.js';
  import 'tippy.js/dist/tippy.css';

  interface TooltipControls {
    disable: () => void;
    enable: () => void;
  }

  const toArray = <T,>(value: T | T[]) => (Array.isArray(value) ? value : [value]);

  const initTechTooltips = (): TooltipControls => {
    const icons = document.querySelectorAll<HTMLElement>('.stack-icon');
    if (!icons.length) {
      return {
        disable: () => {},
        enable: () => {},
      };
    }

    const instances = toArray<Instance>(
      tippy(icons, {
        content: (el) => el.getAttribute('data-label') ?? '',
        placement: 'top',
        arrow: true,
        duration: [150, 100],
        theme: 'wilman',
      }),
    );

    return {
      disable: () => {
        instances.forEach((instance) => {
          instance.hide();
          instance.disable();
        });
      },
      enable: () => {
        instances.forEach((instance) => {
          instance.enable();
        });
      },
    };
  };

  const initTypewriter = () => {
    const roles = [
      'Desarrollador Web',
      'Desarrollador Movil',
      'Full Stack Developer',
      'Freelancer',
    ];
    const typingElement = document.getElementById('typing') as HTMLElement | null;

    if (!typingElement) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      typingElement.textContent = roles[0];
      return;
    }

    let currentRoleIndex = 0;
    let currentCharIndex = 0;
    let isDeleting = false;

    const animateTyping = () => {
      const currentRole = roles[currentRoleIndex];
      currentCharIndex += isDeleting ? -1 : 1;
      typingElement.textContent = currentRole.substring(0, currentCharIndex);

      if (!isDeleting && currentCharIndex === currentRole.length) {
        isDeleting = true;
        window.setTimeout(animateTyping, 1500);
        return;
      }

      if (isDeleting && currentCharIndex === 0) {
        isDeleting = false;
        currentRoleIndex = (currentRoleIndex + 1) % roles.length;
        window.setTimeout(animateTyping, 500);
        return;
      }

      window.setTimeout(animateTyping, isDeleting ? 50 : 80);
    };

    animateTyping();
  };

  const initStackCarousel = (tooltips: TooltipControls) => {
    const container = document.getElementById('hero-stack') as HTMLElement | null;
    const track = document.getElementById('stack-track') as HTMLElement | null;
    if (!container || !track) return;

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const SPEED = 0.6;
    const STEP_KEY = 60;
    const RESUME_DELAY = 2000;

    let offset = 0;
    let autoScrollActive = !reducedMotion;
    let isDragging = false;
    let dragStartX = 0;
    let dragStartOffset = 0;
    let touchStartX = 0;
    let touchStartOffset = 0;
    let resumeTimer = 0;

    const getHalfWidth = () => Math.max(track.scrollWidth / 2, 1);

    const clampOffset = (value: number) => {
      const half = getHalfWidth();
      return -(((-value) % half + half) % half);
    };

    const applyOffset = () => {
      track.style.transform = `translateX(${offset}px)`;
    };

    const pauseAutoScroll = (resume = true) => {
      autoScrollActive = false;
      window.clearTimeout(resumeTimer);

      if (resume && !reducedMotion) {
        resumeTimer = window.setTimeout(() => {
          autoScrollActive = true;
        }, RESUME_DELAY);
      }
    };

    const tick = () => {
      if (autoScrollActive) {
        offset = clampOffset(offset - SPEED);
        applyOffset();
      }
      window.requestAnimationFrame(tick);
    };

    if (!reducedMotion) {
      window.requestAnimationFrame(tick);
    }

    const handleMouseMove = (event: MouseEvent) => {
      if (!isDragging) return;
      const delta = event.clientX - dragStartX;
      offset = clampOffset(dragStartOffset + delta);
      applyOffset();
    };

    const handleMouseUp = () => {
      if (!isDragging) return;
      isDragging = false;
      container.style.cursor = '';
      tooltips.enable();
      pauseAutoScroll(true);
      window.removeEventListener('mousemove', handleMouseMove);
      window.removeEventListener('mouseup', handleMouseUp);
    };

    container.addEventListener('mouseenter', () => {
      if (!isDragging) pauseAutoScroll(false);
    });

    container.addEventListener('mouseleave', () => {
      if (!isDragging && !reducedMotion) autoScrollActive = true;
    });

    container.addEventListener('mousedown', (event: MouseEvent) => {
      isDragging = true;
      dragStartX = event.clientX;
      dragStartOffset = offset;
      pauseAutoScroll(false);
      tooltips.disable();
      container.style.cursor = 'grabbing';
      window.addEventListener('mousemove', handleMouseMove);
      window.addEventListener('mouseup', handleMouseUp);
      event.preventDefault();
    });

    container.addEventListener(
      'touchstart',
      (event: TouchEvent) => {
        touchStartX = event.touches[0].clientX;
        touchStartOffset = offset;
        pauseAutoScroll(false);
        tooltips.disable();
      },
      { passive: true },
    );

    container.addEventListener(
      'touchmove',
      (event: TouchEvent) => {
        const delta = event.touches[0].clientX - touchStartX;
        offset = clampOffset(touchStartOffset + delta);
        applyOffset();
      },
      { passive: true },
    );

    container.addEventListener('touchend', () => {
      tooltips.enable();
      pauseAutoScroll(true);
    });

    container.addEventListener('keydown', (event: KeyboardEvent) => {
      if (event.key === 'ArrowLeft') {
        offset = clampOffset(offset + STEP_KEY);
        applyOffset();
        pauseAutoScroll(true);
        event.preventDefault();
      }

      if (event.key === 'ArrowRight') {
        offset = clampOffset(offset - STEP_KEY);
        applyOffset();
        pauseAutoScroll(true);
        event.preventDefault();
      }
    });

    window.addEventListener('resize', () => {
      offset = clampOffset(offset);
      applyOffset();
    });
  };

  const tooltipControls = initTechTooltips();
  initTypewriter();
  initStackCarousel(tooltipControls);
</script>

<style>
  @keyframes blink {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0; }
  }

  .typing-cursor {
    animation: blink 0.7s infinite;
    font-weight: 300;
  }

  .hero-photo {
    aspect-ratio: 1;
  }

  .hero-photo::before {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    background: var(--gradient-diag);
    z-index: -1;
  }

  .hero-photo::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    background: var(--gradient-diag);
    filter: blur(28px);
    opacity: 0.45;
    z-index: -2;
  }

  .hero-stack {
    -webkit-mask: linear-gradient(90deg, transparent, white 12%, white 88%, transparent);
    mask: linear-gradient(90deg, transparent, white 12%, white 88%, transparent);
    padding-top: 6px;
    padding-bottom: 10px;
    margin-top: -6px;
    cursor: grab;
    user-select: none;
  }

  .hero-stack:active {
    cursor: grabbing;
  }

  .stack-track {
    will-change: transform;
  }

  @media (prefers-reduced-motion: reduce) {
    .typing-cursor {
      animation: none;
    }
  }

  .stack-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 10px;
    background: rgba(125, 71, 255, 0.1);
    border: 1px solid rgba(125, 71, 255, 0.25);
    transition: all 0.2s;
    cursor: default;
    flex-shrink: 0;
  }

  .stack-icon i {
    font-size: 1.35rem;
  }

  .stack-icon:hover {
    background: rgba(125, 71, 255, 0.22);
    border-color: var(--color-purple);
    transform: translateY(-3px);
    box-shadow: 0 6px 18px rgba(125, 71, 255, 0.3);
  }

  .tippy-box[data-theme~='wilman'] {
    background: rgba(27, 8, 64, 0.97);
    color: #0CFFFF;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    border: 1px solid rgba(12, 255, 255, 0.3);
    border-radius: 6px;
  }

  .tippy-box[data-theme~='wilman'] .tippy-arrow {
    color: rgba(27, 8, 64, 0.97);
  }
</style>
