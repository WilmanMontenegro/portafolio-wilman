---

---

<section
    class="section-wrapper"
    id="contact"
    aria-labelledby="contact-title"
>
    <p class="font-mono text-[0.82rem] text-cyan/65 mb-2 tracking-[0.05em]" aria-hidden="true">
        &lt;section&gt; contact
    </p>
    <h2
        class="grad-text font-mono text-[clamp(1.7rem,3vw,2.4rem)] font-bold mb-2"
        id="contact-title"
    >
        ¿Tienes un proyecto en mente?
    </h2>
    <p class="font-mono text-muted text-[0.85rem] mb-[clamp(2rem,5vw,3rem)]">
        // Cuéntame qué necesitas y lo resolvemos juntos
    </p>

    <div
        class="grid items-start gap-[clamp(2rem,5vw,4rem)] md:grid-cols-[1fr_2fr]"
    >
        <!-- Info lateral -->
        <div
            class="grid gap-7 rounded-xl border border-purple/20 bg-purple/10 p-5 md:p-7"
        >
            <div class="grid gap-1.5">
                <span class="font-mono text-[0.72rem] text-cyan/60"
                    >// email</span
                >
                <a
                    href="mailto:wilmanmc15@gmail.com"
                    class="break-all font-mono text-[0.88rem] text-cyan transition-opacity hover:opacity-70"
                    >wilmanmc15@gmail.com</a
                >
            </div>
            <div class="grid gap-1.5">
                <span class="font-mono text-[0.72rem] text-cyan/60"
                    >// ubicacion</span
                >
                <span class="break-all font-mono text-[0.88rem] text-text"
                    >Santa Marta, Colombia</span
                >
            </div>
            <div class="grid gap-1.5">
                <span class="font-mono text-[0.72rem] text-cyan/60"
                    >// disponibilidad</span
                >
                <span
                    class="flex items-center gap-2 text-[0.88rem] text-green-400"
                    ><span
                        class="h-[7px] w-[7px] rounded-full bg-green-400 motion-safe:animate-pulse motion-reduce:animate-none"
                    ></span>Disponible para proyectos</span
                >
            </div>
        </div>

        <!-- Formulario -->
        <form
            id="contact-form"
            action="https://formspree.io/f/xjgajljq"
            method="POST"
            class="grid gap-5"
            novalidate
        >
            <div class="grid gap-5 sm:grid-cols-2">
                <div class="grid gap-2">
                    <label
                        for="name"
                        class="font-mono text-[0.75rem] text-cyan/70"
                        >Nombre</label
                    >
                    <input
                        type="text"
                        id="name"
                        name="name"
                        placeholder="Tu nombre"
                        required
                        autocomplete="name"
                        class="w-full rounded-lg border border-purple/25 bg-[rgba(27,8,64,0.6)] px-4 py-3 font-mono text-[0.9rem] text-text outline-none transition-[border-color,box-shadow] placeholder:text-[rgba(180,170,210,0.35)] focus-visible:border-purple/60 focus-visible:outline-2 focus-visible:outline-cyan/60 focus-visible:shadow-[0_0_0_3px_rgba(125,71,255,0.12)]"
                    />
                </div>
                <div class="grid gap-2">
                    <label
                        for="email"
                        class="font-mono text-[0.75rem] text-cyan/70"
                        >Correo</label
                    >
                    <input
                        type="email"
                        id="email"
                        name="email"
                        placeholder="tu@correo.com"
                        required
                        autocomplete="email"
                        spellcheck="false"
                        class="w-full rounded-lg border border-purple/25 bg-[rgba(27,8,64,0.6)] px-4 py-3 font-mono text-[0.9rem] text-text outline-none transition-[border-color,box-shadow] placeholder:text-[rgba(180,170,210,0.35)] focus-visible:border-purple/60 focus-visible:outline-2 focus-visible:outline-cyan/60 focus-visible:shadow-[0_0_0_3px_rgba(125,71,255,0.12)]"
                    />
                </div>
            </div>

            <div class="grid gap-2">
                <label
                    for="message"
                    class="font-mono text-[0.75rem] text-cyan/70">Mensaje</label
                >
                <textarea
                    id="message"
                    name="message"
                    placeholder="Cuéntame de tu proyecto…"
                    rows="5"
                    required
                    class="min-h-[130px] w-full resize-none rounded-lg border border-purple/25 bg-[rgba(27,8,64,0.6)] px-4 py-3 font-mono text-[0.9rem] text-text outline-none transition-[border-color,box-shadow] placeholder:text-[rgba(180,170,210,0.35)] focus-visible:border-purple/60 focus-visible:outline-2 focus-visible:outline-cyan/60 focus-visible:shadow-[0_0_0_3px_rgba(125,71,255,0.12)]"
                ></textarea>
            </div>

            <div class="flex flex-wrap items-center gap-5">
                <button
                    type="submit"
                    class="btn btn--primary relative min-w-40 disabled:cursor-not-allowed disabled:opacity-60"
                    id="submit-btn"
                >
                    <span data-role="btn-text">Enviar mensaje</span>
                    <span
                        data-role="btn-loading"
                        class="hidden"
                        aria-hidden="true">Enviando…</span
                    >
                </button>
                <p
                    class="font-mono text-[0.8rem] text-muted"
                    id="form-status"
                    role="alert"
                    aria-live="polite"
                >
                </p>
            </div>
        </form>
    </div>
    <p
        class="font-mono text-[0.82rem] text-cyan/65 mt-2 mb-0 text-right tracking-[0.05em]"
        aria-hidden="true"
    >
        &lt;/section&gt;
    </p>
</section>

<script>
    const form = document.getElementById(
        "contact-form",
    ) as HTMLFormElement | null;
    const submitBtn = document.getElementById(
        "submit-btn",
    ) as HTMLButtonElement | null;
    const status = document.getElementById("form-status") as HTMLElement | null;
    const btnText = submitBtn?.querySelector(
        '[data-role="btn-text"]',
    ) as HTMLElement | null;
    const btnLoading = submitBtn?.querySelector(
        '[data-role="btn-loading"]',
    ) as HTMLElement | null;

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (!form || !submitBtn || !status) return;

        btnText?.classList.add("hidden");
        btnLoading?.classList.remove("hidden");
        submitBtn.disabled = true;
        status.textContent = "";
        status.className = "font-mono text-[0.8rem] text-muted";

        try {
            const res = await fetch(form.action, {
                method: "POST",
                body: new FormData(form),
                headers: { Accept: "application/json" },
            });

            if (res.ok) {
                status.textContent = "// Mensaje enviado. Te respondo pronto.";
                status.classList.add("text-green-400");
                form.reset();
            } else {
                throw new Error("server");
            }
        } catch {
            status.textContent =
                "// Algo falló. Escríbeme directo a wilmanmc15@gmail.com";
            status.classList.add("text-red-400");
        } finally {
            btnText?.classList.remove("hidden");
            btnLoading?.classList.add("hidden");
            submitBtn.disabled = false;
        }
    });
</script>
