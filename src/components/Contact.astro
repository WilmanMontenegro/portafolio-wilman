---
---

<section class="py-[clamp(4rem,10vw,7rem)] px-[clamp(1.25rem,5vw,3rem)] max-w-[var(--max-w)] mx-auto" id="contact" aria-labelledby="contact-title">
  <p class="font-mono text-[0.75rem] text-cyan/55 mb-2 tracking-[0.05em]"><span class="text-cyan/65 text-[0.82em]">&lt;section&gt;</span> contact</p>
  <h2 class="grad-text font-mono text-[clamp(1.7rem,3vw,2.4rem)] font-bold mb-2" id="contact-title">¿Tienes un proyecto en mente?</h2>
  <p class="font-mono text-muted text-[0.85rem] mb-[clamp(2rem,5vw,3rem)]">// Cuéntame qué necesitas y lo resolvemos juntos</p>

  <div class="contact-grid">

    <!-- Info lateral -->
    <div class="contact-info">
      <div class="info-item">
        <span class="info-label">// email</span>
        <a href="mailto:wilmanmc15@gmail.com" class="info-value">wilmanmc15@gmail.com</a>
      </div>
      <div class="info-item">
        <span class="info-label">// ubicacion</span>
        <span class="info-value">Santa Marta, Colombia</span>
      </div>
      <div class="info-item">
        <span class="info-label">// disponibilidad</span>
        <span class="info-value available"><span class="dot"></span>Disponible para proyectos</span>
      </div>
    </div>

    <!-- Formulario -->
    <form
      id="contact-form"
      action="https://formspree.io/f/xjgajljq"
      method="POST"
      class="contact-form"
      novalidate
    >
      <div class="field-group">
        <div class="field">
          <label for="name" class="field__label">Nombre</label>
          <input
            type="text"
            id="name"
            name="name"
            placeholder="Tu nombre"
            required
            autocomplete="name"
            class="field__input"
          />
        </div>
        <div class="field">
          <label for="email" class="field__label">Correo</label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder="tu@correo.com"
            required
            autocomplete="email"
            spellcheck="false"
            class="field__input"
          />
        </div>
      </div>

      <div class="field">
        <label for="message" class="field__label">Mensaje</label>
        <textarea
          id="message"
          name="message"
          placeholder="Cuéntame de tu proyecto…"
          rows="5"
          required
          class="field__input field__textarea"
        ></textarea>
      </div>

      <div class="form-footer">
        <button type="submit" class="btn btn--primary btn--submit" id="submit-btn">
          <span class="btn-text">Enviar mensaje</span>
          <span class="btn-loading" aria-hidden="true">Enviando…</span>
        </button>
        <p class="form-status" id="form-status" role="alert" aria-live="polite"></p>
      </div>
    </form>

  </div>
  <p class="font-mono text-[0.82rem] text-cyan/65 mt-10 mb-0 text-right tracking-[0.05em]">&lt;/section&gt;</p>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const status = document.getElementById('form-status') as HTMLElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !submitBtn || !status) return;

    submitBtn.classList.add('loading');
    submitBtn.disabled = true;
    status.textContent = '';
    status.className = 'form-status';

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        status.textContent = '// Mensaje enviado. Te respondo pronto.';
        status.classList.add('success');
        form.reset();
      } else {
        throw new Error('server');
      }
    } catch {
      status.textContent = '// Algo falló. Escríbeme directo a wilmanmc15@gmail.com';
      status.classList.add('error');
    } finally {
      submitBtn.classList.remove('loading');
      submitBtn.disabled = false;
    }
  });
</script>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  /* ── Info lateral ── */
  .contact-info {
    display: grid;
    gap: 1.75rem;
    padding: 1.75rem;
    border: 1px solid rgba(125, 71, 255, 0.2);
    border-radius: 12px;
    background: rgba(125, 71, 255, 0.05);
  }

  .info-item {
    display: grid;
    gap: 0.3rem;
  }

  .info-label {
    font-family: var(--font-family-mono);
    font-size: 0.72rem;
    color: var(--color-cyan);
    opacity: 0.6;
  }

  .info-value {
    font-family: var(--font-family-mono);
    font-size: 0.88rem;
    color: var(--color-text);
    word-break: break-all;
  }

  a.info-value {
    color: var(--color-cyan);
    transition: opacity 0.2s;
  }

  a.info-value:hover {
    opacity: 0.7;
  }

  .available {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #4ade80 !important;
  }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #4ade80;
    flex-shrink: 0;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.5; transform: scale(0.85); }
  }

  @media (prefers-reduced-motion: reduce) {
    .dot { animation: none; }
    .field__input { transition: none; }
  }

  /* ── Formulario ── */
  .contact-form {
    display: grid;
    gap: 1.25rem;
  }

  .field-group {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .field {
    display: grid;
    gap: 0.45rem;
  }

  .field__label {
    font-family: var(--font-family-mono);
    font-size: 0.75rem;
    color: var(--color-cyan);
    opacity: 0.7;
  }

  .field__input {
    width: 100%;
    padding: 0.75rem 1rem;
    background: rgba(27, 8, 64, 0.6);
    border: 1px solid rgba(125, 71, 255, 0.25);
    border-radius: 8px;
    color: var(--color-text);
    font-family: var(--font-family-mono);
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .field__input::placeholder {
    color: rgba(180, 170, 210, 0.35);
  }

  .field__input:focus,
  .field__input:focus-visible {
    border-color: rgba(125, 71, 255, 0.6);
    box-shadow: 0 0 0 3px rgba(125, 71, 255, 0.12);
  }

  .field__textarea {
    resize: vertical;
    min-height: 130px;
  }

  /* ── Footer del form ── */
  .form-footer {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .btn--submit {
    position: relative;
    min-width: 160px;
  }

  .btn-loading {
    display: none;
  }

  .btn--submit.loading .btn-text   { display: none; }
  .btn--submit.loading .btn-loading { display: inline; }

  .btn--submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .form-status {
    font-family: var(--font-family-mono);
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  .form-status.success { color: #4ade80; }
  .form-status.error   { color: #f87171; }

  /* ── Responsive ── */
  @media (max-width: 860px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .field-group {
      grid-template-columns: 1fr;
    }
  }
</style>
